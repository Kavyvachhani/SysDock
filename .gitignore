# Python build artifacts — never commit these
dist/
build/
*.egg-info/
__pycache__/
*.pyc
*.pyo
.eggs/

# Virtual envs
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# PyInstaller — EXE and spec files stay local only
*.spec
*.exe

# Local macOS package build artifacts
mac/*.pkg
pkg_root_local/
