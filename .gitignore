# Python build artifacts — never commit these
dist/
build/
*.egg-info/
.eggs/
__pycache__/
*.pyc
*.pyo

# Test / type caches
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# Virtual envs
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
# macOS AppleDouble metadata
._*

# PyInstaller — EXE and spec files stay local only
*.spec
*.exe

# Local macOS package build artifacts
mac/*.pkg
pkg_root_local/
